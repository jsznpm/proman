{
  "name": "promaster",
  "version": "1.5.0",
  "description": "Interactive CLI to browse Markdown (blog/memory/books) from a public GitHub repo and save it as browser-ready HTML.",
  "type": "module",
  "bin": {
    "promaster": "./bin/promaster.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "build:win": "bun build ./bin/promaster.js --compile --target=bun-windows-x64 --outfile dist/promaster-win.exe",
    "build:mac": "bun build ./bin/promaster.js --compile --target=bun-darwin-arm64 --outfile dist/promaster-mac-arm64",
    "build:mac-intel": "bun build ./bin/promaster.js --compile --target=bun-darwin-x64 --outfile dist/promaster-mac-x64",
    "build:linux": "bun build ./bin/promaster.js --compile --target=bun-linux-x64 --outfile dist/promaster-linux",
    "build:all": "bun run build:win && bun run build:mac && bun run build:mac-intel && bun run build:linux"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "markdown",
    "github",
    "blog",
    "notes",
    "html"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "marked": "^14.0.0"
  }
}
